{
  "name": "universal-react-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo dev",
    "mobile": "pnpm --filter mobile dev",
    "mobile:android": "pnpm --filter mobile android",
    "mobile:ios": "pnpm --filter mobile ios",
    "mobile:web": "pnpm --filter mobile web",
    "web": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:start": "pnpm --filter web start",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "sync-legal": "node scripts/sync-legal-content.mjs",
    "verify-migration": "node scripts/verify-migration.mjs",
    "postinstall": "(patch-package --patch-dir apps/mobile/patches || true) && for f in apps/mobile/scripts/patch-callkeep.sh apps/mobile/scripts/patch-expo-dev-launcher.sh apps/mobile/scripts/patch-insta-story.sh apps/mobile/scripts/patch-react-native-gradle-plugin.sh apps/mobile/scripts/patch-screen-transitions.sh apps/mobile/scripts/patch-vision-camera.sh; do [ -f \"$f\" ] && bash \"$f\" || true; done",
    "verify:parity": "node scripts/verify-port-parity.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "turbo": "^2.9.17"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "react-native": "0.86.0",
      "react-native-reanimated": "4.4.1",
      "react-native-worklets": "0.9.2",
      "react-native-web": "0.21.2",
      "@expo/dom-webview": "56.0.5",
      "hermes-compiler": "250829098.0.14",
      "react-native-nitro-modules": "0.35.6",
      "lightningcss": "1.30.1"
    },
    "onlyBuiltDependencies": [
      "@fishjam-cloud/react-native-webrtc",
      "@shopify/react-native-skia",
      "@swc/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
