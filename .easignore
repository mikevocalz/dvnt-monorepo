# EAS archives the git ROOT in monorepos, so this lives at the repo root
# (PROMPT 0 §4.5). Anchored native paths are rebased onto apps/mobile, and the
# local Expo modules' native sources (now under packages/*) are kept.

# Dependencies
node_modules/
**/node_modules/
package-lock.json
yarn.lock

# Expo / build outputs
.expo/
**/.expo/
dist/
**/dist/
web-build/
expo-env.d.ts
.turbo/
**/.turbo/

# Native builds — regenerated by prebuild; do NOT upload the app's ios/android.
/apps/mobile/ios/
/apps/mobile/android/

# ...but DO keep native sources of local Expo modules (moved from modules/ → packages/*)
!packages/**/ios/
!packages/**/ios/**
!packages/**/android/
!packages/**/android/**

*.orig.*
*.aab
*.apks

# Signing keys & certificates
*.jks
*.p8
*.p12
*.key
*.keystore
*.mobileprovision
*.cer
*.certSigningRequest

# Metro bundler
.metro-health-check*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# Web apps — not part of the mobile EAS archive
apps/web/
apps/web-vite/
