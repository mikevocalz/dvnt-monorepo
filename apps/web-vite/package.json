{
  "name": "web-vite",
  "version": "0.1.0",
  "private": true,
  "description": "DVNT admin — Payload v4 (TanStack Start, Vite) moderation dashboard + blog CMS on Supabase Postgres",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning vite build",
    "dev": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning vite dev",
    "start": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning vite preview --host 0.0.0.0 --port ${PORT:-3000}",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "seed:admins": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed-admins.ts",
    "seed:posts": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed-posts.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dvnt/cms": "workspace:*",
    "@expo/html-elements": "^0.13.1",
    "@faceless-ui/window-info": "^3.0.1",
    "@payloadcms/admin-bar": "4.0.0-internal.a0ef1b8",
    "@payloadcms/db-postgres": "4.0.0-internal.a0ef1b8",
    "@payloadcms/drizzle": "4.0.0-internal.a0ef1b8",
    "@payloadcms/graphql": "4.0.0-internal.a0ef1b8",
    "@payloadcms/live-preview-react": "4.0.0-internal.a0ef1b8",
    "@payloadcms/next": "4.0.0-internal.a0ef1b8",
    "@payloadcms/richtext-lexical": "4.0.0-internal.a0ef1b8",
    "@payloadcms/tanstack-start": "4.0.0-internal.a0ef1b8",
    "@payloadcms/translations": "4.0.0-internal.a0ef1b8",
    "@payloadcms/ui": "4.0.0-internal.a0ef1b8",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.2",
    "graphql-http": "^1.22.4",
    "lucide-react": "0.563.0",
    "payload": "4.0.0-internal.a0ef1b8",
    "pg": "^8.13.1",
    "qs-esm": "^7.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-web": "^0.21.2",
    "scheduler": "^0.25.0",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "22.19.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.26",
    "autoprefixer": "^10.4.19",
    "eslint": "^9",
    "postcss": "^8.4.38",
    "react-server-dom-webpack": "^19.2.6",
    "sass": "^1.77.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "5.7.3",
    "vite": "^8.0.0"
  }
}
