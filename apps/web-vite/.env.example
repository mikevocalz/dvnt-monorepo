# Payload admin secret (any long random string)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# DVNT Supabase Postgres — use the 6543 pooler connection string.
# Payload writes only into the `payload` schema (push:false).
DATABASE_URI=postgres://postgres.npfjanxturvmjyevoyfo:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Public origin of THIS admin app (used for CORS/CSRF + getServerSideURL).
NEXT_PUBLIC_SERVER_URL=http://localhost:5173

# The Vite RN-web moderation dashboard origin (allowed in CORS/CSRF).
FRONTEND_ORIGIN=http://localhost:5173

# Blog public render (apps/web) — live-preview deep links + post canonical.
BLOG_ORIGIN=https://blog.dvntapp.live
PREVIEW_SECRET=change-me-shared-with-apps-web

# Salt for one-way ban-evasion key hashes (ban_list).
BAN_LIST_SALT=change-me-ban-salt

# Shared token between the blog (apps/web) and Payload comment endpoints
COMMENT_SERVICE_TOKEN=change-me-shared-comment-token

# Read-only connection to the live app DB (real members/events). Direct
# Supabase connection (db.<project>.supabase.co). Used by src/endpoints/appData.ts.
APP_DATABASE_URL=postgresql://postgres:PASSWORD@db.<project>.supabase.co:5432/postgres
