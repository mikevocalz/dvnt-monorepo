{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "expo": {
    "install": {
      "exclude": [
        "react-native",
        "react-native-reanimated",
        "react-native-worklets"
      ]
    }
  },
  "scripts": {
    "dev": "expo start --clear --dev-client",
    "start": "expo start --clear --dev-client",
    "android": "expo run:android",
    "ios": "expo start --ios --device",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "update:production": "EAS_SKIP_AUTO_FINGERPRINT=1 eas update --channel production --environment production",
    "update:preview": "EAS_SKIP_AUTO_FINGERPRINT=1 eas update --channel preview --environment preview",
    "typecheck": "tsc --noEmit --pretty",
    "lint": "expo lint",
    "check:secrets": "npx ts-node scripts/check-secrets.ts",
    "check:guardrails": "npx ts-node scripts/check-secrets.ts",
    "check:migrations": "node scripts/check-migrations.js",
    "pre-deploy": "bash scripts/pre-deploy-check.sh",
    "lint:critical": "bash scripts/pre-deploy-check.sh",
    "postinstall:native": "cd ../.. && (patch-package --patch-dir apps/mobile/patches || true) && for f in apps/mobile/scripts/patch-callkeep.sh apps/mobile/scripts/patch-expo-dev-launcher.sh apps/mobile/scripts/patch-insta-story.sh apps/mobile/scripts/patch-react-native-gradle-plugin.sh apps/mobile/scripts/patch-screen-transitions.sh apps/mobile/scripts/patch-vision-camera.sh; do [ -f \"$f\" ] && bash \"$f\" || true; done"
  },
